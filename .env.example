# LLM Gateway credentials
OPENAI_API_KEY=sk-...

# Optional: use a custom OpenAI-compatible base URL (e.g. Azure, Ollama, LM Studio)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default model if not specified in prompt candidate
DEFAULT_MODEL=gpt-4o-mini

# Default max tokens for LLM calls
DEFAULT_MAX_TOKENS=1024

# Timeout in seconds for each LLM request
LLM_TIMEOUT_SECONDS=60

# Number of retries on transient errors
LLM_MAX_RETRIES=3

# Path to the SQLite database file
DB_PATH=data/prompt_evolve.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
